# vim: ft=dosini

[general]
decoration=yes
#compositor = no
[list]
all=yes
order = numeric

[info.viewer]
top_left=+name,+filesize,+imagesize,+exif

[viewer]
history=10
preload=10
window = #000000ff

[keys.viewer]
h = step_left 10
j = step_down 10
k = step_up 10
l = step_right 10
Left = prev_file
Right = next_file
ScrollUp = zoom +5 mouse
ScrollDown = zoom -5 mouse
MouseSide = prev_file
MouseExtra = next_file
MouseMiddle = zoom fit
